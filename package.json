{
  "name": "fhir-test-data",
  "version": "0.1.3",
  "description": "TypeScript library and CLI for generating valid FHIR R4/R4B/R5 test resources with country-aware identifiers",
  "author": "Daniel Veronez",
  "license": "MIT",
  "homepage": "https://dnlbox.github.io/fhir-test-data/",
  "keywords": [
    "fhir",
    "hl7",
    "healthcare",
    "fhir-test-data",
    "test-data",
    "fixtures",
    "synthetic-data",
    "r4",
    "r4b",
    "r5",
    "fhir-r4",
    "cli",
    "identifiers",
    "nhs",
    "medicare",
    "aadhaar",
    "bsn",
    "npi",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dnlbox/fhir-test-data.git"
  },
  "bugs": {
    "url": "https://github.com/dnlbox/fhir-test-data/issues"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "bin": {
    "fhir-test-data": "./dist/cli/index.js"
  },
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./faults": {
      "import": "./dist/core/faults/index.js",
      "types": "./dist/core/faults/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "cli": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:dev": "vitepress dev docs/site",
    "docs:build": "vitepress build docs/site",
    "docs:preview": "vitepress preview docs/site",
    "prepare": "lefthook install",
    "prepublishOnly": "pnpm build && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "lefthook": "^2.1.8",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  }
}
