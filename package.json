{
  "name": "fhir-test-data",
  "version": "0.1.0",
  "description": "TypeScript library and CLI for generating valid FHIR R4/R4B/R5 test resources with country-aware identifiers",
  "author": "Daniel Veronez",
  "license": "MIT",
  "keywords": [
    "fhir",
    "hl7",
    "healthcare",
    "fhir-test-data",
    "test-data",
    "synthetic-data",
    "r4",
    "r4b",
    "r5",
    "fhir-r4",
    "cli",
    "identifiers",
    "nhs",
    "us-core",
    "au-core",
    "uk-core"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dnlbox/fhir-test-data.git"
  },
  "bugs": {
    "url": "https://github.com/dnlbox/fhir-test-data/issues"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "bin": {
    "fhir-test-data": "./dist/cli/index.js"
  },
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
